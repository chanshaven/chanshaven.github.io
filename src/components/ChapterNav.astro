---
import { getPostUrlBySlug } from "@utils/url-utils";

interface Props {
	currentSlug: string;
	chapters: any[];
}

const { currentSlug, chapters } = Astro.props;

const sortedChapters = [...chapters].sort((a, b) => {
	const ca = a.data.chapter ?? 9999;
	const cb = b.data.chapter ?? 9999;
	return ca - cb;
});

const currentIndex = sortedChapters.findIndex((p) => p.slug === currentSlug);
const current = sortedChapters[currentIndex];
const prev = currentIndex > 0 ? sortedChapters[currentIndex - 1] : null;
const next =
	currentIndex >= 0 && currentIndex < sortedChapters.length - 1
		? sortedChapters[currentIndex + 1]
		: null;

const currentLabel = current?.data.chapter
	? `Chương ${current.data.chapter}`
	: "Chương hiện tại";
---

{current && sortedChapters.length > 0 && (
	<nav class="chapter-nav">
		<a
			href={prev ? getPostUrlBySlug(prev.slug) : "#"}
			class:list={["chapter-btn chapter-side", { disabled: !prev }]}
			aria-disabled={!prev}
		>
			<span class="chapter-arrow">‹</span>
			<span>Chương trước</span>
		</a>

		<details class="chapter-dropdown">
			<summary class="chapter-btn chapter-current">
				<span class="chapter-current-main">{currentLabel}</span>
				{current.data.chapterTitle && (
					<span class="chapter-current-sub">{current.data.chapterTitle}</span>
				)}
			</summary>

			<div class="chapter-list">
	            <div class="chapter-list-title">Danh sách chương</div>

                <div class="chapter-search">
                    <input
                        class="chapter-search-input"
                        type="search"
                        placeholder="Tìm chương, ví dụ: 6 hoặc hồ..."
                        autocomplete="off"
                    />
                </div>

                {sortedChapters.map((post) => {
                    const isCurrent = post.slug === currentSlug;
                    const label = post.data.chapter
                        ? `Chương ${post.data.chapter}`
                        : post.data.title;

                    const chapterName = post.data.chapterTitle || post.data.title;

                    return (
                        <a
                            href={getPostUrlBySlug(post.slug)}
                            data-chapter={post.data.chapter ?? ""}
                            data-search={`${label} ${chapterName}`.toLowerCase()}
                            class:list={["chapter-list-item", { active: isCurrent }]}
                        >
                            <span class="chapter-list-number">{label}</span>
                            <span class="chapter-list-name">
                                {chapterName}
                            </span>
                        </a>
                    );
                })}
            </div>
		</details>

		<a
			href={next ? getPostUrlBySlug(next.slug) : "#"}
			class:list={["chapter-btn chapter-side", { disabled: !next }]}
			aria-disabled={!next}
		>
			<span>Chương sau</span>
			<span class="chapter-arrow">›</span>
		</a>
	</nav>
)}

<style>
	.chapter-nav {
		display: grid;
		grid-template-columns: 1fr minmax(160px, 1.15fr) 1fr;
		gap: 0.75rem;
		margin: 1rem 0 1.5rem;
		position: relative;
		z-index: 20;
	}

	.chapter-btn {
		min-height: 3.4rem;
		border-radius: 1.1rem;
		border: 1px solid rgba(216, 106, 169, 0.18);
		background:
			linear-gradient(135deg, rgba(255, 250, 253, 0.95), rgba(255, 236, 246, 0.86));
		color: #c85b9b;
		box-shadow: 0 10px 24px rgba(216, 106, 169, 0.1);
		text-decoration: none !important;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		font-weight: 800;
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}

	.chapter-btn:hover {
		transform: translateY(-2px);
		border-color: rgba(216, 106, 169, 0.34);
		box-shadow: 0 14px 30px rgba(216, 106, 169, 0.16);
	}

	.chapter-btn.disabled {
		pointer-events: none;
		opacity: 0.38;
		filter: grayscale(0.2);
	}

	.chapter-arrow {
		font-size: 1.7rem;
		line-height: 1;
		margin-top: -0.1rem;
	}

	.chapter-dropdown {
		position: relative;
	}

	.chapter-dropdown summary {
		list-style: none;
		cursor: pointer;
	}

	.chapter-dropdown summary::-webkit-details-marker {
		display: none;
	}

	.chapter-current {
		flex-direction: column;
		gap: 0.1rem;
		background:
			radial-gradient(circle at top left, rgba(255, 210, 232, 0.95), transparent 40%),
			linear-gradient(135deg, #e37ab4, #d86aa9);
		color: white;
		border-color: rgba(255, 255, 255, 0.25);
		box-shadow: 0 14px 32px rgba(216, 106, 169, 0.28);
	}

	.chapter-current-main {
		font-size: 1rem;
		line-height: 1.1;
	}

	.chapter-current-sub {
		font-size: 0.82rem;
		font-weight: 650;
		opacity: 0.9;
		max-width: 100%;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		padding: 0 0.75rem;
	}

	.chapter-list {
		position: absolute;
		left: 50%;
		top: calc(100% + 0.65rem);
		transform: translateX(-50%);
		width: min(28rem, 88vw);
		max-height: 22rem;
		overflow-y: auto;
		padding: 0.75rem;
		border-radius: 1.25rem;
		border: 1px solid rgba(216, 106, 169, 0.2);
		background: rgba(255, 250, 253, 0.98);
		box-shadow: 0 22px 55px rgba(118, 60, 94, 0.18);
		backdrop-filter: blur(12px);
	}

	.chapter-list-title {
		position: sticky;
		top: -0.75rem;
		z-index: 1;
		padding: 0.75rem 0.75rem 0.6rem;
		margin: -0.75rem -0.75rem 0.45rem;
		background: rgba(255, 250, 253, 0.98);
		color: #c85b9b;
		font-weight: 850;
		border-bottom: 1px dashed rgba(216, 106, 169, 0.22);
	}

	.chapter-list-item {
		display: grid;
		grid-template-columns: 5.8rem 1fr;
		gap: 0.65rem;
		align-items: center;
		padding: 0.75rem 0.8rem;
		border-radius: 0.95rem;
		text-decoration: none !important;
		color: #6b5967;
		transition:
			background 0.16s ease,
			color 0.16s ease,
			transform 0.16s ease;
	}

	.chapter-list-item:hover {
		background: rgba(255, 229, 242, 0.78);
		color: #c85b9b;
		transform: translateX(2px);
	}

	.chapter-list-item.active {
		background: linear-gradient(135deg, rgba(227, 122, 180, 0.16), rgba(255, 229, 242, 0.8));
		color: #c85b9b;
		font-weight: 800;
	}

	.chapter-list-number {
		font-weight: 850;
		font-size: 0.9rem;
	}

	.chapter-list-name {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	@media (max-width: 700px) {
		.chapter-nav {
			grid-template-columns: 1fr;
		}

		.chapter-list {
			left: 0;
			right: 0;
			transform: none;
			width: 100%;
		}
	}

    .chapter-search {
	position: sticky;
	top: 2.95rem;
	z-index: 2;
	margin: 0 -0.75rem 0.55rem;
	padding: 0.65rem 0.75rem;
	background: rgba(255, 250, 253, 0.98);
	border-bottom: 1px dashed rgba(216, 106, 169, 0.16);
    }

    .chapter-search-input {
        width: 100%;
        border: 1px solid rgba(216, 106, 169, 0.2);
        border-radius: 0.9rem;
        padding: 0.7rem 0.85rem;
        background: rgba(255, 255, 255, 0.78);
        color: #6b5967;
        font-weight: 650;
        outline: none;
    }

    .chapter-search-input::placeholder {
        color: rgba(107, 89, 103, 0.48);
    }

    .chapter-search-input:focus {
        border-color: rgba(216, 106, 169, 0.6);
        box-shadow: 0 0 0 4px rgba(255, 185, 215, 0.22);
    }

    .chapter-list-item[hidden] {
        display: none;
    }
</style>


<script>
	function initChapterNavAutoScroll() {
		document.querySelectorAll(".chapter-dropdown").forEach((dropdown) => {
			if (dropdown.dataset.autoScrollReady === "true") return;
			dropdown.dataset.autoScrollReady = "true";

			const input = dropdown.querySelector(".chapter-search-input");
			const list = dropdown.querySelector(".chapter-list");

			function filterChapters() {
				const q = input?.value?.trim().toLowerCase() || "";
				const items = dropdown.querySelectorAll(".chapter-list-item");

				let firstVisible = null;

				items.forEach((item) => {
					const chapter = item.dataset.chapter || "";
					const searchText = item.dataset.search || "";

					const matched =
						!q ||
						chapter === q ||
						chapter.startsWith(q) ||
						searchText.includes(q);

					item.hidden = !matched;

					if (matched && !firstVisible) {
						firstVisible = item;
					}
				});

				return firstVisible;
			}

			dropdown.addEventListener("toggle", () => {
				if (!dropdown.open) return;

				requestAnimationFrame(() => {
					const active = dropdown.querySelector(".chapter-list-item.active");

					if (list && active) {
						list.scrollTop =
							active.offsetTop -
							list.clientHeight / 2 +
							active.clientHeight / 2;
					}

					if (input) {
						input.value = "";
						filterChapters();

						// Tự focus trên desktop, tránh mobile tự bật bàn phím quá đột ngột
						if (window.innerWidth > 700) {
							input.focus();
						}
					}
				});
			});

			input?.addEventListener("input", () => {
				filterChapters();
			});

			input?.addEventListener("keydown", (event) => {
				if (event.key !== "Enter") return;

				const firstVisible = filterChapters();

				if (firstVisible) {
					event.preventDefault();
					firstVisible.click();
				}
			});
		});

		if (document.documentElement.dataset.chapterOutsideClickReady === "true") return;
		document.documentElement.dataset.chapterOutsideClickReady = "true";

		document.addEventListener("click", (event) => {
			document.querySelectorAll(".chapter-dropdown[open]").forEach((dropdown) => {
				if (!dropdown.contains(event.target)) {
					dropdown.removeAttribute("open");
				}
			});
		});

		document.addEventListener("keydown", (event) => {
			if (event.key !== "Escape") return;

			document.querySelectorAll(".chapter-dropdown[open]").forEach((dropdown) => {
				dropdown.removeAttribute("open");
			});
		});
	}

	document.addEventListener("astro:page-load", initChapterNavAutoScroll);
	initChapterNavAutoScroll();
</script>